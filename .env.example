# MongoDB connection string (Atlas or self-hosted)
MONGO_DB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/

# AWS credentials for S3 + ECR + EC2
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=us-east-1

# DagsHub — MLflow Tracking + DVC Remote
# Get token from: https://dagshub.com/user/settings/tokens
DAGSHUB_USER_TOKEN=your_dagshub_token
MLFLOW_TRACKING_URI=https://dagshub.com/<your-dagshub-username>/APS-failure-classification.mlflow
MLFLOW_TRACKING_USERNAME=<your-dagshub-username>
MLFLOW_TRACKING_PASSWORD=your_dagshub_token
